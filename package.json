{
	"name": "realistdb",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.12",
	"engines": {
		"node": ">=20.11",
		"bun": ">=1.1"
	},
	"workspaces": {
		"packages": [
			"packages/**",
			"docs"
		],
		"catalog": {
			"typescript": "6.0.3",
			"@biomejs/biome": "2.4.12",
			"ultracite": "7.6.0",
			"turbo": "2.9.6"
		},
		"catalogs": {
			"testing": {
				"vitest": "4.1.4",
				"@vitest/coverage-v8": "4.1.4",
				"fast-check": "4.7.0",
				"@stryker-mutator/core": "9.6.1",
				"@stryker-mutator/vitest-runner": "9.6.1",
				"testcontainers": "11.14.0"
			},
			"build": {
				"tsdown": "0.21.9",
				"publint": "0.3.18",
				"@arethetypeswrong/cli": "0.18.2",
				"size-limit": "12.1.0",
				"@size-limit/preset-small-lib": "12.1.0",
				"knip": "6.4.1"
			},
			"release": {
				"@changesets/cli": "2.31.0",
				"@commitlint/cli": "20.5.0",
				"@commitlint/config-conventional": "20.5.0",
				"@commitlint/types": "20.5.0",
				"lefthook": "2.1.6"
			},
			"types": {
				"@types/node": "25.6.0",
				"@types/bun": "1.3.12"
			},
			"docs": {
				"astro": "6.1.8",
				"@astrojs/check": "0.9.8",
				"@astrojs/starlight": "0.38.3",
				"starlight-typedoc": "0.21.5",
				"typedoc": "0.28.19",
				"typedoc-plugin-markdown": "4.11.0"
			}
		}
	},
	"trustedDependencies": [],
	"scripts": {
		"setup": "lefthook install",
		"build": "turbo run build",
		"test": "turbo run test",
		"test:mutate": "turbo run test:mutate",
		"test:integration": "turbo run test:integration",
		"typecheck": "turbo run typecheck",
		"lint": "biome check .",
		"format": "biome format --write .",
		"fix": "biome check --write .",
		"check:publint": "turbo run check:publint",
		"check:attw": "turbo run check:attw",
		"check:knip": "knip --include files,dependencies,unlisted,binaries,exports",
		"check:catalog": "bun run scripts/check-catalog.ts",
		"check:size": "turbo run check:size",
		"check:size-budgets": "bun run scripts/check-size-budgets.ts",
		"scripts:test": "bun test scripts/",
		"verify": "turbo run build typecheck test check:publint check:attw check:size && bun run lint && bun run check:knip && bun run check:catalog && bun run check:size-budgets && bun run scripts:test",
		"ci": "bun run verify",
		"changeset": "changeset",
		"release": "changeset publish",
		"new:package": "bun run scripts/new-package.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@changesets/cli": "catalog:release",
		"@commitlint/cli": "catalog:release",
		"@commitlint/config-conventional": "catalog:release",
		"@commitlint/types": "catalog:release",
		"@realistdb/biome-config": "workspace:*",
		"@types/bun": "catalog:types",
		"knip": "catalog:build",
		"lefthook": "catalog:release",
		"turbo": "catalog:",
		"ultracite": "catalog:"
	}
}
